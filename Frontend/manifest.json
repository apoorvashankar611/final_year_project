{
  "manifest_version": 3,
  "name": "PhishShield",
  "version": "1.1",
  "description": "Detects phishing URLs and phishing text on social media websites.",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "notifications",
    "webNavigation"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png"
  },

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:8000/*",
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.facebook.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.linkedin.com/*",
        "*://*.youtube.com/*",
        "*://*.tiktok.com/*",
        "*://*.pinterest.com/*",
        "*://*.snapchat.com/*",
        "*://*.reddit.com/*"
      ],
      "js": ["text_detector.js"],
      "run_at": "document_idle"
    }
  ]
}   